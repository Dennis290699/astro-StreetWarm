---
import Layout from '../layouts/Layout.astro';
import ShopContent from '../components/shop/ShopContent';
---

<Layout title="Shop - StreetWarm">
  <main class="main bg-white min-h-screen pt-24 pb-12">
    <div class="max-w-7xl mx-auto px-6 2xl:px-0 mb-8 text-center md:text-left">
      <span class="inline-block py-1 px-3 rounded-full bg-orange-50 text-[var(--first-color)] text-sm font-bold tracking-widest uppercase mb-4 shadow-sm">
        Our Collection
      </span>
      <h1 class="text-4xl md:text-5xl text-[var(--title-color)] font-black leading-tight">
        Shop <span class="text-[var(--first-color)]">Now</span>
      </h1>
      <p class="text-gray-500 mt-4 max-w-xl mx-auto md:mx-0">
        Browse our exclusive and premium streetwear collections. Find everything you need to elevate your everyday style.
      </p>
    </div>

    <!-- Client Island -->
    <ShopContent client:load />
  </main>
</Layout>

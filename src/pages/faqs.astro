---
import Layout from '../layouts/Layout.astro';
import FaqAccordion from '../components/faqs/FaqAccordion.tsx';
---

<Layout title="FAQ's | StreetWarm">
  <main class="bg-white min-h-screen pt-24 pb-20 overflow-hidden relative">
    
    {/* Decorative Elements */}
    <div class="absolute top-40 right-0 w-96 h-96 bg-[var(--first-color)]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 -z-10"></div>
    <div class="absolute bottom-40 left-0 w-96 h-96 bg-[var(--title-color)]/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 -z-10"></div>

    {/* HEADER PAGE */}
    <div class="max-w-7xl mx-auto px-6 2xl:px-0 py-12 md:py-16 text-center">
      <span class="inline-block py-1.5 px-4 rounded-full bg-orange-50 text-[var(--first-color)] text-sm font-bold tracking-widest uppercase mb-4 shadow-sm">
        Help Center
      </span>
      <h1 class="text-4xl md:text-6xl text-[var(--title-color)] font-black leading-tight mb-6">
        Frequently Asked <span class="text-[var(--first-color)]">Questions</span>
      </h1>
      <p class="text-gray-500 max-w-2xl mx-auto text-lg mb-12">
        Have questions about our products, shipping, returns or policies? Find all the answers you need below.
      </p>

      {/* REACT COMPONENT ISLA */}
      <div class="mt-8">
        <FaqAccordion client:only="react" />
      </div>

    </div>
    
    {/* Still have questions banner */}
    <div class="max-w-4xl mx-auto px-6 mt-12 text-center">
       <div class="bg-gray-50 rounded-[2rem] p-10 md:p-14 border border-gray-100 shadow-[0_5px_15px_rgba(0,0,0,0.02)]">
         <div class="w-16 h-16 bg-white text-[var(--title-color)] rounded-full flex items-center justify-center text-3xl mx-auto mb-6 shadow-sm border border-gray-100">
           <i class='bx bx-support'></i>
         </div>
         <h3 class="text-2xl md:text-3xl font-black text-[var(--title-color)] mb-4">Still have questions?</h3>
         <p class="text-gray-500 mb-8 max-w-md mx-auto">
           Can't find the answer you're looking for? Please chat to our friendly team.
         </p>
         <a href="/contact" class="inline-flex items-center justify-center gap-3 bg-[var(--title-color)] text-white px-8 py-4 rounded-full font-bold transition-all duration-300 hover:bg-[var(--first-color)] hover:shadow-lg hover:shadow-[var(--first-color)]/30 hover:-translate-y-1">
           Get in touch
         </a>
       </div>
    </div>
  </main>
</Layout>
